{
  "schema": "elementary.chat-startup-context-bundle.v1",
  "status": "ACTIVE_AFTER_MERGE_SAFE_PUBLIC_MIRROR",
  "repository": "borislavppetrov-beep/elementary-construction-os",
  "canonical_branch": "main",
  "purpose": "Mandatory compact startup context for every ELEMENTARY controlled chat, specialist chat, governed agent, transfer package and resume package.",
  "source_of_truth_rule": {
    "status": "REQUIRED",
    "primary_source_of_truth": "live GitHub repository on canonical branch main",
    "knowledge_upload_role": "fallback bootstrap only",
    "must_prefer_live_repository_when_available": true,
    "must_report_when_using_static_snapshot": true,
    "static_snapshot_may_be_stale": true
  },
  "startup_rule": {
    "status": "REQUIRED",
    "must_read_before_capability_claim": true,
    "must_read_before_runtime_version_claim": true,
    "must_read_before_repeated_problem_diagnosis": true,
    "must_read_before_execution": true,
    "must_read_before_result_or_artifact_claim": true,
    "chat_only_memory_allowed": false,
    "full_problem_solution_ledger_loaded_by_default": false,
    "compact_generated_memory_loaded_by_default": true,
    "result_artifact_writeback_loaded_by_default": true
  },
  "memory_rule": {
    "status": "ACTIVE",
    "compact_startup_first": true,
    "deep_ledger_retrieval_only_when_relevant": true,
    "memory_kernel": "contracts/governance/memory-kernel-v1.json",
    "startup_hotset": "contracts/governance/generated/startup-memory-hotset-v1.json",
    "problem_solution_router": "contracts/governance/generated/problem-solution-router-v1.json",
    "problem_solution_index": "contracts/governance/generated/problem-solution-index-v1.jsonl"
  },
  "result_artifact_writeback_rule": {
    "status": "ACTIVE",
    "policy": "contracts/governance/result-artifact-writeback-policy-v1.json",
    "registry": "contracts/governance/result-artifact-registry-v1.jsonl",
    "router": "contracts/governance/generated/result-artifact-router-v1.json",
    "every_governed_output_must_be_registered": true,
    "evidence_reference_required": true,
    "sha256_or_commit_or_artifact_digest_required_for_file_code_or_bundle": true,
    "problem_solution_entry_required_when_output_changes_operational_learning": true,
    "full_evidence_retrieval_only_when_relevant": true
  },
  "read_order": [
    {"order":1,"path":"docs/governance/ELEMENTARY_CHAT_CAPABILITY_BOOTSTRAP.md","reason":"Global capability, authorization, drift and startup behavior."},
    {"order":2,"path":"contracts/governance/owner-resource-authorization-v1.json","reason":"Owner resource authorization and standing limitations."},
    {"order":3,"path":"contracts/governance/canonical-software-runtime-inventory-v1.json","reason":"Exact runtime and software inventory."},
    {"order":4,"path":"contracts/governance/memory-kernel-v1.json","reason":"Rules for compact cross-chat learning and deep ledger retrieval."},
    {"order":5,"path":"contracts/governance/generated/startup-memory-hotset-v1.json","reason":"Compact active and high-priority problem/solution memory for startup."},
    {"order":6,"path":"contracts/governance/generated/problem-solution-router-v1.json","reason":"Machine routing by scope, active blockers and exact symptom signatures."},
    {"order":7,"path":"contracts/governance/generated/problem-solution-index-v1.jsonl","reason":"Compact machine-readable problem/solution index."},
    {"order":8,"path":"contracts/governance/result-artifact-writeback-policy-v1.json","reason":"Rules requiring produced governed outputs and artifacts to be registered."},
    {"order":9,"path":"contracts/governance/result-artifact-registry-v1.jsonl","reason":"Machine-readable registry of governed outputs, artifacts and evidence references."},
    {"order":10,"path":"contracts/governance/generated/result-artifact-router-v1.json","reason":"Compact routing rules for deciding when and how to register produced outputs."}
  ],
  "required_startup_attestation_fields": [
    "CHAT_STARTUP_CONTEXT_BUNDLE_LOADED",
    "CAPABILITY_BOOTSTRAP_LOADED",
    "OWNER_RESOURCE_AUTHORIZATION_LOADED",
    "CANONICAL_SOFTWARE_INVENTORY_LOADED",
    "MEMORY_KERNEL_LOADED",
    "STARTUP_MEMORY_HOTSET_LOADED",
    "PROBLEM_SOLUTION_ROUTER_LOADED",
    "PROBLEM_SOLUTION_INDEX_LOADED",
    "RESULT_ARTIFACT_WRITEBACK_POLICY_LOADED",
    "RESULT_ARTIFACT_REGISTRY_LOADED",
    "RESULT_ARTIFACT_ROUTER_LOADED",
    "LIVE_GITHUB_SOURCE_OF_TRUTH_CHECKED",
    "STATIC_KNOWLEDGE_SNAPSHOT_USED_ONLY_AS_FALLBACK",
    "CAPABILITY_BOUNDARY_CHECKED_BEFORE_LIMITATION_CLAIM",
    "RUNTIME_INVENTORY_CHECKED_BEFORE_VERSION_CLAIM",
    "COMPACT_MEMORY_CHECKED_BEFORE_REPEATED_PROBLEM_DIAGNOSIS",
    "RESULT_ARTIFACT_WRITEBACK_CHECKED_BEFORE_RESULT_CLAIM",
    "TRANSFER_PACKAGE_INSTRUCTS_NEW_CHAT_TO_READ_STARTUP_BUNDLE"
  ],
  "drift_writeback_rule": {
    "capability_or_authorization_drift": "Update owner resource authorization or create blocking issue.",
    "software_or_runtime_drift": "Update canonical software runtime inventory or create blocking issue.",
    "problem_or_solution_drift": "Update problem/solution memory or create safe overlay when full-file update is risky.",
    "generated_memory_drift": "Run memory compiler and refresh generated problem/solution artifacts.",
    "result_or_artifact_output": "Register the produced output in the result/artifact registry or create a safe overlay if full-file update is risky.",
    "startup_rule_drift": "Update startup bundle and capability bootstrap."
  },
  "limits": {
    "restricted_value_disclosure": false,
    "fabricated_evidence": false,
    "ungoverned_unrestricted_shell": false,
    "uncontrolled_destructive_actions": false
  }
}
