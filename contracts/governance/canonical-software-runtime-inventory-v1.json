  "purpose": "Canonical software, language, framework and runtime inventory for every ELEMENTARY chat and governed agent.",
  "rules": {
    "must_load_during_chat_bootstrap": true,
    "must_not_invent_versions": true,
    "unknown_versions_must_be_marked_unverified": true,
    "live_readback_overrides_stale_documentation": true,
    "secret_values_must_not_be_collected": true,
    "must_update_canonical_inventory_on_version_or_availability_drift": true,
    "chat_only_version_record_allowed": false
  },
  "mandatory_runtime_drift_updates": {
    "status": "REQUIRED",
    "rule": "Any chat, governed agent, live collector or transfer/resume package that discovers, verifies, loses or materially changes a software/runtime version or availability fact must update this canonical inventory or record a blocking follow-up issue if it cannot write.",
    "triggers": [
      "new exact runtime version verified",
      "runtime version upgrade verified",
      "runtime version downgrade verified",
      "runtime becomes unavailable or blocked",
      "previously unavailable runtime becomes available",
      "server, BoCore, runner, WSL, browser, database or build-tool fact changes",
      "composer.json package constraint changes",
      "package.json package constraint changes",
      "composer.lock, package-lock.json, pnpm-lock.yaml, yarn.lock or equivalent exact dependency state changes",
      "HTML, CSS or ECMAScript target standard changes"
    ],
    "required_update_targets": [
      "contracts/governance/canonical-software-runtime-inventory-v1.json",
      "docs/governance/ELEMENTARY_CHAT_CAPABILITY_BOOTSTRAP.md"
    ],
    "required_evidence": [
      "source chat, dispatch, PR, workflow run or collector reference",
      "previous recorded value",
      "new observed value",
      "verification command or evidence source",
      "observation date",
      "impact on production, BoCore, CI, build, browser or deployment behavior"
    ],
    "if_write_path_unavailable": "Create or update a GitHub issue with the evidence and mark the canonical inventory update as pending.",
    "unverified_placeholder": "UNVERIFIED_CURRENT_VERSION",
    "forbidden_behaviors": [
      "leave newly discovered versions only in chat text",
      "guess exact versions from memory",
      "replace a verified exact version with an unverified assumption",
      "collect or print secret values while collecting version evidence"
    ]
  },
