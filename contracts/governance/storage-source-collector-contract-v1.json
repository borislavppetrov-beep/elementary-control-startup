    "topology_artifacts_may_be_compiler_inputs": false,
    "expected_status_until_all_required_sources_are_complete": "INCOMPLETE",
    "remaining_unintegrated_required_sources": [],
    "incomplete_required_sources_must_be_reported": true,
    "global_total_claim_allowed": false,
    "global_total_size_bytes_must_be_null": true,
    "automatic_mapping_allowed": false,
    "source_mutation": false,
    "storage_mutation_performed": false,
    "validator": "scripts/storage/validate_partial_global_storage_summary.py",
    "regression_test": "scripts/storage/test_partial_global_manifest_workflow.py",
