{
  "schema": "elementary.storage-source-collector-contract.v1",
  "status": "ACTIVE",
  "version": "1.9.0",
  "collector_mode": "READ_ONLY_METADATA_ONLY",
  "required_output_format": "JSONL",
  "required_record_fields": ["schema", "source", "collector_id", "collected_at_utc", "scope_id", "object_type", "object_identity", "display_path", "aggregation_domain_id", "size_bytes", "size_accounting_state", "modified_at_utc", "hash_state", "sha256", "symlink_state", "active_use_state", "classification", "disposition_state", "warnings"],
  "rules": {
    "must_not_follow_symlinks": true,
    "must_not_read_file_content_without_hash_authorization": true,
    "hashing_requires_explicit_flag": true,
    "must_not_scan_secret_stores": true,
    "must_not_emit_environment_values": true,
    "must_not_emit_file_content": true,
    "must_not_mutate_source": true,
    "must_report_permission_denied": true,
    "must_report_partial_scope": true,
    "source_control_record_must_be_first": true,
    "unknown_is_not_zero": true
  },
  "size_accounting": {
    "states": ["KNOWN_BYTES", "UNKNOWN_BYTES", "NOT_APPLICABLE"],
    "known_bytes_requires_non_negative_integer_size_bytes": true,
    "unknown_bytes_requires_null_size_bytes": true,
    "not_applicable_requires_null_size_bytes": true,
    "structural_records_must_not_use_directory_stat_size_as_content_bytes": true,
    "unknown_bytes_blocks_global_total": true,
    "not_applicable_does_not_block_size_coverage": true
  },
  "aggregation_domain_admission": {
    "automatic_domain_guessing": false,
    "filesystem_mode": "EXPLICIT_ENTRY_ROOT_MAP",
    "provider_mode": "EXPLICIT_SCOPE_DOMAIN",
    "entry_domain_overrides_control_domain": true,
    "unmapped_size_bearing_entry_behavior": "EXCLUDE_FROM_LOWER_BOUND_AND_BLOCK_GLOBAL_TOTAL",
    "same_domain_within_one_scope": "ALLOWED",
    "same_domain_across_multiple_scopes": "OVERLAP_BLOCKER",
    "duplicate_entry_identity_behavior": "SUPPRESS_IN_COLLECTOR_AND_REJECT_IN_COMPILER",
    "control_first_streaming_required": true,
    "collector_generated_evidence_must_not_be_self_scanned": true
  },
  "root_topology_evidence": {
    "status": "ACTIVE",
    "control_schema": "elementary.storage-root-topology.control.v1",
    "entry_schema": "elementary.storage-root-topology.entry.v1",
    "purpose": "Produce hashed logical-volume candidates for independent review without approving physical aggregation domains.",
    "proposal_only": true,
    "automatic_mapping_allowed": false,
    "physical_domain_proven_by_collector": false,
    "raw_volume_serial_recorded": false,
    "raw_device_identifier_recorded": false,
    "raw_mount_source_recorded": false,
    "candidate_identity": "SHA256_OF_LOCAL_OR_BOUNDED_CAPACITY_VIEW_LOGICAL_VOLUME_EVIDENCE",
    "same_candidate_within_one_source_scope": "LOGICAL_VOLUME_CORRELATION_ONLY",
    "cross_source_equivalence": "NOT_PROVEN",
    "mapping_activation_requires": ["independent_infrastructure_evidence", "explicit_domain_decision", "separate_reviewed_source_change"],
    "validator": "scripts/storage/validate_root_topology_evidence.py",
    "linux_collector": "scripts/storage/collect_linux_root_topology.py",
    "windows_collector": "scripts/storage/collect_windows_root_topology.ps1",
    "cpanel_production_analyzer": "scripts/storage/analyze_cpanel_production_root_topology.py",
    "cpanel_production_input": "SUCCESSFUL_EXACT_SHA_BOUND_IMMUTABLE_INVENTORY_ARTIFACTS_ONLY",
    "cpanel_production_candidate_mode": "HASHED_CAPACITY_VIEW_CORRELATION_ONLY",
    "cpanel_production_live_evidence_required": true
  },
  "manifest_compilation": {
    "compiler": "scripts/storage/build_global_storage_manifest.py",
    "source_artifact_identity": "sha256",
    "duplicate_source_scope_behavior": "FAIL_CLOSED",
    "duplicate_entry_identity_behavior": "FAIL_CLOSED",
    "known_size_aggregation": "KNOWN_BYTES_ONLY",
    "non_complete_source_contribution": "AGGREGATION_SAFE_KNOWN_BYTES_LOWER_BOUND_ONLY",
    "aggregation_domain_id_required_for_global_aggregation": true,
    "overlapping_aggregation_domains_behavior": "EXCLUDE_FROM_LOWER_BOUND_AND_BLOCK_GLOBAL_TOTAL",
    "missing_aggregation_domain_behavior": "EXCLUDE_FROM_LOWER_BOUND_AND_BLOCK_GLOBAL_TOTAL",
    "global_total_claim_requires_all_required_sources_complete": true,
    "global_total_claim_requires_zero_unknown_size_records": true,
    "global_total_claim_requires_complete_aggregation_coverage": true,
    "source_coverage_size_coverage_and_aggregation_coverage_must_be_reported_separately": true,
    "missing_source_is_not_zero": true,
    "partial_source_is_not_complete": true,
    "unknown_size_is_not_zero": true,
    "input_order_must_not_change_output": true,
    "absolute_input_paths_must_not_be_recorded": true,
    "source_artifacts_must_not_be_mutated": true
  },
